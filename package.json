{
	"name": "ran-ecwid-shop-teaser",
	"version": "1.1.0",
	"private": true,
	"description": "Standalone dynamic Ecwid shop teaser block for WordPress.",
	"author": "RAN",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"blocks",
		"gutenberg",
		"ecwid"
	],
	"homepage": "https://github.com/RocketsAreNostalgic/ran-ecwid-shop-teaser",
	"repository": {
		"type": "git",
		"url": "https://github.com/RocketsAreNostalgic/ran-ecwid-shop-teaser.git"
	},
	"bugs": {
		"url": "https://github.com/RocketsAreNostalgic/ran-ecwid-shop-teaser"
	},
	"devDependencies": {
		"@wordpress/scripts": "^30.25.0",
		"typescript": "6.0.3"
	},
	"scripts": {
		"hooks:install": "git config core.hooksPath .githooks",
		"prepare": "git config core.hooksPath .githooks",
		"start": "wp-scripts start --source-path=blocks --output-path=build/blocks",
		"build": "wp-scripts build --source-path=blocks --output-path=build/blocks",
		"format": "prettier --write --ignore-path .prettierignore --ignore-unknown .",
		"format:check": "prettier --check --ignore-path .prettierignore --ignore-unknown .",
		"lint:js": "wp-scripts lint-js",
		"lint:css": "wp-scripts lint-style",
		"lint:pkg-json": "wp-scripts lint-pkg-json",
		"lint:php": "php tools/lint-php.php",
		"i18n:pot": "wp i18n make-pot . languages/ran-ecwid-shop-teaser.pot --exclude=node_modules,build,vendor,tests,dist && php tools/annotate-pot-release-version.php",
		"archive": "php tools/build-release.php",
		"archive:check": "php tools/build-release.php --check",
		"wordpress-org:prepare": "sh tools/prepare-wordpress-org.sh",
		"check": "wp-scripts lint-pkg-json && wp-scripts lint-js && wp-scripts lint-style && pnpm format:check && pnpm lint:php",
		"check:generated": "pnpm build && pnpm i18n:pot && git diff --exit-code -- build/blocks languages/ran-ecwid-shop-teaser.pot",
		"test:php": "composer test",
		"release:verify": "pnpm archive:check"
	},
	"prettier": "@wordpress/prettier-config",
	"packageManager": "pnpm@11.5.2"
}
