<?xml version="1.0"?>
<ruleset name="RAN Ecwid Shop Teaser PHP Compatibility">
	<description>Validate the declared PHP 8.0 baseline.</description>
	<file>ran-ecwid-shop-teaser.php</file>
	<file>includes</file>
	<exclude-pattern>vendor/*</exclude-pattern>
	<config name="testVersion" value="8.0-" />
	<rule ref="PHPCompatibilityWP" />
</ruleset>
